# Production — Fly.io deploy URL'leri
# Bu dosya commit edilebilir (secret içermez, sadece public URL)

# Backend Fly.io URL'i (build-time değişken — vite build sırasında gömülür)
VITE_API_URL=https://kalorispor-backend.fly.dev

# Mobil native app için backend URL (aynı WiFi'da geliştirme)
# Bilgisayarın IP'sini yaz: ipconfig ile öğren
# Örnek: VITE_API_URL_NATIVE=http://192.168.1.100:8000
VITE_API_URL_NATIVE=
